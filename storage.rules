rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Principe de sécurité ──────────────────────────────────────────────────
    // Storage ne peut pas lire Firestore pour vérifier une propriété. On scope
    // donc chaque chemin par l'UID de l'uploadeur : {collection}/{uid}/{...}.
    // La règle exige request.auth.uid == uid → un user ne peut écrire QUE sous
    // son propre préfixe.
    //
    // Compatibilité legacy : le wildcard {uid} matche aussi les anciens chemins
    // ({collection}/{eventId|convId|appId}/...). La LECTURE y reste donc possible
    // (le 1er segment est libre), mais l'ÉCRITURE échoue (auth.uid != eventId),
    // ce qui ferme la faille sans casser l'accès aux fichiers déjà uploadés.
    // De toute façon les fichiers existants sont servis via des URLs à token.

    // Avatars utilisateur
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024;
    }

    // Photos et vidéos des offres prestataires — lecture publique pour que le
    // catalogue soit visible sans compte, écriture réservée au propriétaire.
    match /provider-media/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 36 * 1024 * 1024
                   && request.resource.contentType.matches('(image|video)/.*');
    }

    // Logo, bannière et galerie des pages publiques organisateurs.
    match /organizer-media/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 51 * 1024 * 1024
                   && request.resource.contentType.matches('(image|video)/.*');
    }

    // Documents de candidature — seul le propriétaire écrit sous son préfixe.
    // Empêche l'injection de faux documents dans le dossier d'autrui.
    // ⚠ KYC (pièces d'identité, RIB…) : lecture STRICTEMENT limitée au
    // propriétaire et aux agents. « Tout utilisateur connecté » permettait à
    // n'importe quel inscrit d'aspirer les CNI/IBAN des partenaires
    // (usurpation d'identité + exposition CNIL/RGPD).
    match /applications/{uid}/{allPaths=**} {
      allow read:  if request.auth != null && (
                     request.auth.uid == uid ||
                     firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'agent'
                   );
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 15 * 1024 * 1024;
    }

    // Pièces jointes des messages — seul l'expéditeur écrit sous son préfixe.
    // Lecture réservée aux authentifiés (destinataires via URL à token).
    match /messages/{uid}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 25 * 1024 * 1024;
    }

    // Affiches d'événements — seul l'organisateur écrit sous son préfixe.
    // Empêche le defacement par upload d'affiche d'un tiers. Lecture publique.
    match /events/{uid}/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 8 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

  }
}
