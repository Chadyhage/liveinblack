rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    // Agent = rôle 'agent' sous N'IMPORTE QUELLE forme. switchActiveRole réécrit
    // `role` quand l'admin change d'interface : limiter ce check à `role` rendait
    // les droits admin intermittents (permission-denied jusqu'à re-connexion).
    // enabledRoles est sûr : le propriétaire ne peut pas s'y ajouter 'agent'
    // (voir la règle update de users/{uid} plus bas).
    function isAgent() {
      let me = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isSignedIn() && (
        isSuperAdmin() ||
        me.get('role', '') == 'agent' ||
        me.get('activeRole', '') == 'agent' ||
        'agent' in me.get('enabledRoles', [])
      );
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Super-admin « bootstrap » : seul moyen légitime de poser role:'agent'
    // (les vrais agents sont ensuite créés par un agent existant).
    // ⚠️ LES RÈGLES NE PEUVENT PAS LIRE LES ENV VARS. Cette liste doit donc être
    // tenue à jour À LA MAIN et rester EXACTEMENT égale à VITE_SUPER_ADMIN_EMAILS
    // (Vercel) + VITE_SUPER_ADMIN_EMAILS côté front (src/pages/LoginPage.jsx).
    // Ajouter un super-admin = l'ajouter aux TROIS endroits, sinon il aura les
    // droits front mais sera refusé (403) par ces règles serveur. Ne mettre ici
    // QUE des e-mails réellement de confiance : présence ici = pouvoir total.
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email in ['hagechady4@gmail.com'];
    }

    // Organisateur propriétaire de l'event (createdBy OU organizerId — les deux
    // champs sont toujours écrits ensemble à la création, voir events/{id}).
    function isEventOwnerOf(eventId) {
      let ev = get(/databases/$(database)/documents/events/$(eventId)).data;
      return isSignedIn() && (ev.createdBy == request.auth.uid || ev.organizerId == request.auth.uid);
    }

    // ── Users ──────────────────────────────────────────────────────────────────
    // Read: any signed-in user can see profiles (needed for messaging contacts sync)
    // Write: le propriétaire édite son profil (nom, avatar, confidentialité, switch
    // d'interface…) MAIS ne peut PAS s'auto-promouvoir : role/activeRole = 'agent'
    // est réservé aux agents / super-admin. Ferme l'escalade de privilèges
    // client → agent (isAgent() lit users/{uid}.role, champ que le propriétaire
    // pouvait sinon écrire lui-même).
    match /users/{uid} {
      allow read:   if isSignedIn();
      // Anti-escalade À LA CRÉATION (faille critique #71-audit) : le doc n'existant
      // pas encore, la règle `update` (verrouillée) ne s'applique PAS. Le propriétaire
      // pouvait donc poser directement role:'organisateur' + status:'active' et
      // contourner le KYC + l'abonnement. On force ici l'état initial à refléter
      // EXACTEMENT ce que l'inscription écrit (LoginPage) :
      //  - jamais 'agent' (role/activeRole/enabledRoles) ;
      //  - enabledRoles absent (profil minimal) OU exactement [role] — pas de rôle
      //    pro caché ni de multi-rôles auto-accordés ;
      //  - activeRole cohérent avec role (pas d'interface pro sur un compte client) ;
      //  - un rôle PRO (organisateur/prestataire) NAÎT en 'onboarding', jamais
      //    'active' : l'activation passe par la validation d'un agent (serveur/Admin SDK).
      allow create: if isSuperAdmin() || (isOwner(uid)
        && request.resource.data.get('role', 'client') != 'agent'
        && request.resource.data.get('activeRole', 'client') != 'agent'
        && !('agent' in request.resource.data.get('enabledRoles', []))
        && (!('enabledRoles' in request.resource.data)
            || request.resource.data.enabledRoles == [request.resource.data.get('role', 'client')])
        && request.resource.data.get('activeRole', request.resource.data.get('role', 'client')) == request.resource.data.get('role', 'client')
        && (
            (request.resource.data.get('role', 'client') == 'organisateur' || request.resource.data.get('role', 'client') == 'prestataire')
              ? request.resource.data.get('status', 'onboarding') == 'onboarding'
              : true
        ));
      // Le propriétaire édite son profil MAIS ne peut pas s'octroyer de privilèges :
      //  - jamais role/activeRole = 'agent' (escalade admin) ;
      //  - jamais s'auto-valider (status → 'active' réservé aux agents) ;
      //  - jamais s'auto-accorder un rôle : role ne peut changer QUE vers un rôle
      //    déjà présent dans enabledRoles (ou rester inchangé), et enabledRoles
      //    lui-même n'est pas modifiable. (.get() tolère les vieux docs.)
      //  - jamais 'agent' dans enabledRoles s'il n'y était pas déjà : isAgent()
      //    lit ce champ, un vieux doc sans enabledRoles pouvait sinon se le poser.
      allow update: if isAgent() || isSuperAdmin()
        || (isOwner(uid)
            && request.resource.data.get('role', 'client') != 'agent'
            && request.resource.data.get('activeRole', 'client') != 'agent'
            && (request.resource.data.get('status', '') != 'active' || resource.data.get('status', '') == 'active')
            && (request.resource.data.get('role', 'client') == resource.data.get('role', 'client')
                || request.resource.data.get('role', 'client') in resource.data.get('enabledRoles', [request.resource.data.get('role', 'client')]))
            && (!('enabledRoles' in resource.data) || request.resource.data.enabledRoles == resource.data.enabledRoles)
            && ('agent' in resource.data.get('enabledRoles', []) || !('agent' in request.resource.data.get('enabledRoles', []))));
      allow delete: if isAgent();
    }

    // Pays de facturation prestataire : document séparé de users/{uid}, car les
    // profils de compte sont lisibles par les contacts connectés. Cette donnée ne
    // doit jamais rejoindre les collections publiques providers/ ou catalogues/.
    match /provider_billing/{uid} {
      allow read: if isOwner(uid) || isAgent();
      allow write: if isAgent();
    }

    // ── Applications / candidatures ────────────────────────────────────────────
    match /applications/{id} {
      allow read, write: if isSignedIn() && (
        resource == null ||
        resource.data.uid == request.auth.uid ||
        isAgent()
      );
    }

    // ── Pending validations ────────────────────────────────────────────────────
    // Un utilisateur ne crée/modifie QUE ses propres demandes, et ne peut JAMAIS
    // y inscrire le rôle 'agent' : l'UI admin affiche ces docs avec un bouton
    // « Activer » — une demande forgée { requestedRole:'agent' } validée d'un
    // clic serait une escalade totale (défense en profondeur avec la whitelist
    // GRANTABLE_ROLES côté code).
    match /pending_validations/{id} {
      allow read: if isAgent() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow write: if isAgent() || (isSignedIn()
        && (resource == null || resource.data.uid == request.auth.uid)
        && request.resource.data.get('uid', '') == request.auth.uid
        && request.resource.data.get('requestedRole', '') != 'agent'
        && request.resource.data.get('role', '') != 'agent');
      allow delete: if isAgent() || (isSignedIn() && resource.data.uid == request.auth.uid);
    }

    // ── Wallets ────────────────────────────────────────────────────────────────
    match /wallets/{uid} {
      allow read, write: if isOwner(uid) || isAgent();
    }

    // ── Public events (lecture publique, écriture = organisateur propriétaire ou agent) ──
    match /events/{id} {
      allow read: if true;
      allow write: if isSignedIn() && (
        resource == null ||
        resource.data.createdBy == request.auth.uid ||
        resource.data.organizerId == request.auth.uid ||
        isAgent()
      );
      allow delete: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid ||
        resource.data.organizerId == request.auth.uid ||
        isAgent()
      );
    }

    // ── User data collections ──────────────────────────────────────────────────
    match /user_bookings/{uid} {
      allow read, write: if isOwner(uid) || isAgent();
    }
    match /user_events/{uid} {
      allow read, write: if isOwner(uid) || isAgent();
    }
    match /user_social/{uid} {
      allow read, write: if isOwner(uid) || isAgent();
    }
    // Events privés débloqués par code d'accès — suit l'utilisateur cross-device
    match /user_private_access/{uid} {
      allow read, write: if isOwner(uid);
    }
    // ── Conversations & messages ───────────────────────────────────────────────
    // Membre = présent dans participants (conv directe) ou participantIds (groupe).
    // Les requêtes clientes utilisent déjà array-contains sur ces champs,
    // donc ces règles sont compatibles avec les listeners existants.
    function isMemberOf(data) {
      return request.auth.uid in data.get('participants', [])
          || request.auth.uid in data.get('participantIds', []);
    }

    // Groupes : la liste d'admins et les sourdines sont des données de
    // modération. Une heure d'expiration est stockée en Timestamp afin que la
    // comparaison se fasse avec l'heure serveur, jamais avec l'horloge client.
    function isGroupAdmin(data) {
      return data.get('type', '') == 'group'
          && request.auth.uid in data.get('adminIds', []);
    }

    function isMutedGroupMember(data) {
      let mutes = data.get('memberMutes', {});
      let mute = mutes.get(request.auth.uid, {});
      return data.get('type', '') == 'group'
          && mutes.keys().hasAny([request.auth.uid])
          && mute.get('untilAt', request.time) is timestamp
          && mute.get('untilAt', request.time) > request.time;
    }

    function canUpdateConversation(before, after) {
      // Les membres continuent à mettre à jour le dernier message. En revanche,
      // seuls les admins peuvent changer les droits d'administration ou les
      // sanctions temporaires, ce qui empêche un membre de se réactiver seul.
      return before.get('type', '') != 'group'
          || isGroupAdmin(before)
          || !after.diff(before).affectedKeys().hasAny(['adminIds', 'memberMutes']);
    }

    match /conversations/{id} {
      allow read:   if isSignedIn() && (isMemberOf(resource.data) || isAgent());
      allow create: if isSignedIn() && isMemberOf(request.resource.data);
      allow update: if isSignedIn() && (isMemberOf(resource.data) || isAgent())
          && (isAgent() || canUpdateConversation(resource.data, request.resource.data));
      allow delete: if isSignedIn() && (isMemberOf(resource.data) || isAgent());
    }

    // conv_messages/{convId} : l'ID du doc = l'ID de la conversation.
    // On vérifie l'appartenance via le doc conversation. Si la conversation
    // n'existe pas/plus (création en cours ou suppression), on tolère —
    // nécessaire car les écritures conv/messages ne sont pas transactionnelles.
    match /conv_messages/{convId} {
      allow read, write: if isSignedIn() && (
        !exists(/databases/$(database)/documents/conversations/$(convId)) ||
        (isMemberOf(get(/databases/$(database)/documents/conversations/$(convId)).data)
          && !isMutedGroupMember(get(/databases/$(database)/documents/conversations/$(convId)).data)) ||
        isAgent()
      );
    }

    match /friend_requests/{id} {
      allow read:   if isSignedIn() && (resource.data.toId == request.auth.uid || resource.data.fromId == request.auth.uid || isAgent());
      allow create: if isSignedIn() && request.resource.data.fromId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.toId == request.auth.uid || resource.data.fromId == request.auth.uid || isAgent());
    }


    match /service_orders/{id} {
      allow read:   if isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid || isAgent());
      allow create: if isSignedIn() && (request.resource.data.buyerId == request.auth.uid || request.resource.data.sellerId == request.auth.uid);
      allow update, delete: if isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid || isAgent());
    }

    // ── Photos partagées dans les conversations (fallback base64) ──────────────
    // IDs aléatoires non devinables ; pas de champ convId exploitable en règle.
    match /conv_photos/{id} {
      allow read, write: if isSignedIn();
    }

    // ── Réservations finalisées par le webhook Stripe ──────────────────────────
    // Écrites uniquement par le webhook (Admin SDK). Le client lit la sienne
    // sur /paiement-reussi pour ADOPTER les billets du serveur au lieu d'en
    // générer en double.
    match /bookings/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAgent());
      allow write: if false;
    }

    // ── Marqueurs anti-double-restock (session Stripe expirée → stock relâché) ──
    // Purement serveur (Admin SDK) : empêche le webhook de restocker deux fois si
    // Stripe retente l'envoi du même événement checkout.session.expired.
    match /stock_releases/{sessionId} {
      allow read, write: if false;
    }

    // ── Registre anti-fraude des billets ───────────────────────────────────────
    // Source de vérité du ScannerPage. Seul le webhook Stripe (Admin SDK,
    // qui contourne ces règles) peut écrire paid:true. Côté client :
    // création uniquement avec paid:false (billets gratuits / en attente),
    // jamais de modification ni suppression.
    match /tickets/{code} {
      allow read:   if isSignedIn();
      // Un billet non payé peut être créé côté client (RSVP gratuit, billet
      // optimiste post-paiement) MAIS une invitation `source:'guestlist'` ne peut
      // l'être QUE par l'organisateur/agent — sinon n'importe qui forgeait un
      // faux billet guestlist pour l'événement d'un autre → entrée gratuite. Le
      // droit d'entrée réel (payé / place à 0 / guestlist officielle) est
      // RE-VÉRIFIÉ côté serveur au scan (api/tickets checkin, ticketEntryEntitlement).
      allow create: if isSignedIn()
        && request.resource.data.paid == false
        && (
          request.resource.data.source != 'guestlist'
          || isEventOwnerOf(request.resource.data.eventId)
          || isAgent()
        );
      // L'agent peut tout modifier (validation scanner, etc). L'organisateur de
      // l'event ne peut QUE révoquer une invitation guestlist ou marquer un
      // check-in (jamais flipper `paid`, qui resterait réservé au webhook Stripe).
      // _syncedAt est ajouté automatiquement par syncDoc() à CHAQUE écriture
      // (voir firestore-sync.js) — doit être autorisé sinon le merge échoue.
      allow update: if isAgent() || (
        isEventOwnerOf(resource.data.eventId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['revoked', 'revokedAt', 'checkedInAt', 'checkedInBy', '_syncedAt'])
      );
      allow delete: if isAgent();
    }

    // ── Guestlist par événement (gérée par l'organisateur) ──────────────────────
    match /guestlists/{eventId} {
      allow read, write: if isEventOwnerOf(eventId) || isAgent();
    }
    // ── Statut de lecture cross-device ────────────────────────────────────────
    match /user_read_status/{uid} {
      allow read, write: if isOwner(uid) || isAgent();
    }

    // ── Playlists événements (lecture publique) ────────────────────────────────
    // Modération réservée au DJ / organisateur / agent. Le champ `nowPlaying`
    // (bannière « En ce moment » diffusée à TOUTE la salle) ne peut être écrit
    // que par eux : sinon n'importe quel connecté défigurait la soirée en direct.
    // Un participant peut toujours proposer/liker des sons (le tableau `songs`
    // n'est pas inspectable élément par élément par les règles), mais jamais
    // toucher nowPlaying.
    function isPlaylistManager(eventId) {
      return isEventOwnerOf(eventId) || isAgent() || (
        isSignedIn() &&
        exists(/databases/$(database)/documents/staff_assignments/$(eventId + '__' + request.auth.uid)) &&
        get(/databases/$(database)/documents/staff_assignments/$(eventId + '__' + request.auth.uid)).data.role == 'dj'
      );
    }
    match /event_playlists/{id} {
      allow read: if true;
      // Création : tout connecté (1er son), mais sans poser nowPlaying.
      allow create: if isSignedIn() && !('nowPlaying' in request.resource.data);
      // MAJ : le manager peut tout ; les autres ne peuvent pas toucher nowPlaying.
      allow update: if isSignedIn() && (
        isPlaylistManager(id) ||
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['nowPlaying'])
      );
      allow delete: if isPlaylistManager(id);
    }

    // ── Boosts ────────────────────────────────────────────────────────────────
    match /user_boosts/{uid} {
      allow read:  if isOwner(uid) || isAgent();
      allow write: if isAgent();
    }

    // Collection globale des boosts actifs — source de vérité partagée du Top 3.
    // Lecture PUBLIQUE (le Top 3 doit s'afficher pour les visiteurs non connectés).
    // Écriture réservée au webhook Stripe (Admin SDK, contourne ces règles) :
    // un client ne doit jamais pouvoir s'auto-attribuer un slot Top 3 sans payer.
    match /boosts/{id} {
      allow read:  if true;
      allow write: if isAgent();
    }

    // Verrous transactionnels des emplacements Top 1/2/3. Écriture uniquement
    // via les fonctions serveur (Admin SDK) ; lecture réservée à l'administration.
    match /boost_slots/{id} {
      allow read:  if isAgent();
      allow write: if false;
    }

    // ── Billets scannés ────────────────────────────────────────────────────────
    match /used_tickets/{uid} {
      allow read, write: if isOwner(uid) || isAgent();
    }

    // ── Notifications in-app (cross-device) ─────────────────────────────────────
    // Sans cette règle, la collection était en deny par défaut → la sync
    // cross-device des notifications échouait silencieusement.
    match /notifications/{uid} {
      allow read, write: if isOwner(uid) || isAgent();
    }

    // ── Codes d'accès aux événements privés ─────────────────────────────────────
    // Collection plate {code} → { eventId, usedBy }. L'organisateur crée les
    // codes, le client connecté les valide (lookup O(1)) et marque usedBy.
    // Lecture/écriture réservée aux connectés (un code est un secret d'accès).
    match /event_access_codes/{code} {
      allow read, write: if isSignedIn();
    }

    // ── Signalements ──────────────────────────────────────────────────────────
    // AVANT : write ouvert à tout connecté + ID = Date.now() devinable → n'importe
    // qui pouvait écraser/supprimer/clôturer un signalement d'abus (falsifier la
    // file de modération). Désormais : on ne CRÉE que son propre signalement
    // (fromId = soi), et seul un agent modifie/clôture/supprime (audit admin #1).
    match /reports/{id} {
      allow read:   if isAgent();
      allow create: if isAgent() || (isSignedIn() && request.resource.data.fromId == request.auth.uid);
      allow update, delete: if isAgent();
    }

    // ── Pages publiques organisateurs ───────────────────────────────────────
    // Les requêtes publiques doivent filtrer status == 'public'. Un brouillon,
    // une page masquée ou suspendue reste lisible uniquement par son propriétaire
    // et l'admin. Le public ne reçoit jamais de liste nominative d'abonnés.
    match /organizer_profiles/{uid} {
      allow read: if resource.data.status == 'public' || isOwner(uid) || isAgent();
      allow create: if isOwner(uid) || isAgent();
      allow update: if isOwner(uid) || isAgent() || (
        isSignedIn() && resource.data.status == 'public' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'followersCount', 'viewsCount', 'eventClicksCount', '_syncedAt'
        ]) &&
        request.resource.data.followersCount >= 0 &&
        (
          request.resource.data.followersCount == resource.data.followersCount + 1 ||
          request.resource.data.followersCount == resource.data.followersCount - 1 ||
          request.resource.data.viewsCount == resource.data.viewsCount + 1 ||
          request.resource.data.eventClicksCount == resource.data.eventClicksCount + 1
        )
      );
      allow delete: if isOwner(uid) || isAgent();
    }

    // Un document par client. Le propriétaire gère ses choix ; l'organisateur
    // suivi ne peut ni lire ni requêter l'identité de ses abonnés.
    match /organizer_follows/{uid} {
      allow read, write: if isOwner(uid) || isAgent();
    }

    // ── Index inversé des abonnés (e-mails « nouvel événement ») ───────────────
    // organizer_subscribers/{organizerId}__{uid} = { organizerId, uid, newEventEmail }.
    // Écrit par l'ABONNÉ lui-même (id verrouillé sur son uid). L'organisateur ne
    // peut PAS lire la liste nominative de ses abonnés : seul le serveur (Admin
    // SDK, api/send-email type new_event_followers) la parcourt pour envoyer les
    // e-mails. L'adresse
    // e-mail n'est pas stockée ici (résolue côté serveur depuis Firebase Auth).
    match /organizer_subscribers/{id} {
      allow read: if isAgent() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create, update: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && id == request.resource.data.organizerId + '__' + request.auth.uid;
      allow delete: if isAgent() || (isSignedIn() && resource.data.uid == request.auth.uid);
    }
    // event_notifications/{eventId} : flag d'idempotence des envois d'e-mails —
    // serveur uniquement (aucune règle = accès refusé au client, c'est voulu).

    // ── Codes promo par événement ───────────────────────────────────────────────
    // event_promos/{eventId} = { items: [{ code, type, value, maxUses, usedCount,
    // expiresAt, active }] }. SEUL l'organisateur (ou un agent) lit/écrit la liste :
    // un acheteur ne peut pas énumérer les codes — il en saisit un et le serveur
    // (api/event-stock action 'validate_promo', puis checkout/fedapay) le valide.
    match /event_promos/{eventId} {
      allow read, write: if isEventOwnerOf(eventId) || isAgent();
    }

    match /organizer_slugs/{slug} {
      allow read: if true;
      allow create: if isAgent() || (isSignedIn() && request.resource.data.organizerId == request.auth.uid);
      allow update, delete: if isAgent() || (isSignedIn() && resource.data.organizerId == request.auth.uid);
    }

    match /organizer_reports/{id} {
      allow read: if isAgent();
      allow create: if isSignedIn() && request.resource.data.reporterUserId == request.auth.uid;
      allow update, delete: if isAgent();
    }

    // ── Demandes de suppression de compte ─────────────────────────────────────
    match /deletion_requests/{id} {
      allow read:  if isAgent() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow write: if isAgent() || (isSignedIn() && (resource == null || resource.data.uid == request.auth.uid));
    }

    // Anomalies financières créées uniquement par les webhooks (Admin SDK).
    // L'agent les consulte et les clôture après vérification/remboursement.
    match /payment_alerts/{id} {
      allow read, update: if isAgent();
      allow create, delete: if false;
    }

    // ── Profils prestataires ──────────────────────────────────────────────────
    // Lecture PUBLIQUE : la vitrine /prestataires et les pages prestataires sont
    // accessibles sans compte (le doc ne contient que des infos publiées par le
    // prestataire lui-même : nom de page, description, numéro pro, photos).
    match /providers/{uid} {
      allow read:  if true;
      allow write: if isOwner(uid) || isAgent();
    }

    // ── Catalogues (lecture publique pour la vitrine) ─────────────────────────
    match /catalogs/{uid} {
      allow read:  if true;
      allow write: if isOwner(uid) || isAgent();
    }

    // ── Avis clients sur les prestataires ─────────────────────────────────────
    // provider_reviews/{providerId__authorUid} — écrits UNIQUEMENT par le
    // serveur (api/provider-reviews, Admin SDK) : note, statut et badge
    // « vérifié » ne sont jamais forgés côté client. Lecture : les avis PUBLIÉS
    // sont publics (la page prestataire est publique) ; un avis masqué reste
    // lisible par son auteur, le prestataire concerné et les agents (dashboards).
    match /provider_reviews/{id} {
      allow read: if resource.data.status == 'published'
        || (isSignedIn() && resource.data.authorId == request.auth.uid)
        || (isSignedIn() && resource.data.providerId == request.auth.uid)
        || isAgent();
      allow write: if false;
    }

    // Signalements d'avis — l'identité du signaleur ne doit JAMAIS être visible
    // du prestataire ni de l'auteur (risque de représailles) : lecture agent
    // uniquement, écriture serveur uniquement (api/provider-reviews 'report').
    match /provider_review_reports/{id} {
      allow read:  if isAgent();
      allow write: if false;
    }

    // Journal d'audit des actions admin (modération d'avis…) — écrit par le
    // serveur, consulté par les agents.
    match /admin_audit/{id} {
      allow read:  if isAgent();
      allow write: if false;
    }

    // ── Paiements d'abonnement prestataire (historique) ───────────────────────
    // Écrit UNIQUEMENT par le serveur (webhook FedaPay, Admin SDK). Lecture
    // réservée au prestataire concerné (providerUid) et aux agents.
    match /subscription_payments/{txnId} {
      allow read:  if isAgent() || (isSignedIn() && resource.data.providerUid == request.auth.uid);
      allow write: if false;
    }

    // ── Soldes vendeurs (ledger de reversement) ───────────────────────────────
    // Montant que la plateforme doit au vendeur quand le paiement n'a pas été
    // reversé automatiquement via Stripe Connect (ex. vendeur hors zone Stripe).
    // Écrit UNIQUEMENT par le webhook Stripe (Admin SDK, contourne ces règles) :
    // un vendeur ne doit jamais pouvoir gonfler son propre solde.
    match /seller_balances/{uid} {
      allow read:  if isOwner(uid) || isAgent();
      // Incrémenté par le webhook (Admin SDK, contourne ces règles). L'agent peut
      // décrémenter le solde au moment d'un reversement manuel (admin de confiance).
      allow write: if isAgent();
    }

    // ── Demandes de reversement (paiement manuel : virement / mobile money) ────
    // Le vendeur crée une demande sur SON solde ; l'agent la traite (marque payé).
    match /payout_requests/{id} {
      allow read:   if isSignedIn() && (resource.data.sellerId == request.auth.uid || isAgent());
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isAgent();
    }

    // ── Journal des reversements effectués (audit) ────────────────────────────
    match /payout_logs/{id} {
      allow read:  if isAgent();
      allow write: if isAgent();
    }

    // ── Recettes par événement → versement AUTO en fin d'événement ────────────
    // Écrit uniquement par le serveur (webhook FedaPay + cron, Admin SDK).
    // L'organisateur peut lire l'enveloppe de SES événements (transparence).
    match /event_payouts/{eventId} {
      allow read:  if isAgent() || (isSignedIn() && resource.data.sellerUid == request.auth.uid);
      allow write: if false;
    }

    // ── Remboursements d'événements annulés (#71) ─────────────────────────────
    // event_refunds/{eventId__paymentRef} — créés par le serveur (cancel_event +
    // webhooks, Admin SDK). Stripe = 'refunded' (auto) ; FedaPay = 'pending_manual'
    // (worklist à traiter dans le dashboard FedaPay). L'AGENT lit la liste et peut
    // marquer un remboursement mobile money comme fait (update status). Création/
    // suppression réservées au serveur.
    match /event_refunds/{id} {
      allow read:   if isAgent();
      allow update: if isAgent();
      allow create, delete: if false;
    }

    // ── Journal des annulations d'événements (audit admin, #71) ───────────────
    // Écrit par le serveur (cancel_event, Admin SDK). Lecture agent uniquement.
    match /event_cancellations/{eventId} {
      allow read:  if isAgent();
      allow write: if false;
    }

    // ── Staff d'un événement (roster serveur/manager) — mini-POS soirée ───────
    // Lecture : tout connecté (un serveur doit pouvoir lire son propre rôle).
    // Écriture : seul le propriétaire de l'event (manager implicite) ou un agent
    // gère le roster.
    match /event_staff/{eventId} {
      allow read:  if isSignedIn();
      allow write: if isAgent() || isEventOwnerOf(eventId);
    }

    // ── Index inversé des affectations staff (1 doc = 1 event × 1 membre) ──────
    // staff_assignments/{eventId__uid} = { eventId, uid, role, eventName, addedBy, addedAt }.
    // Requêtable par uid (where uid==me) → le membre liste « ses soirées » et
    // débloque l'accès scanner. Écriture réservée au propriétaire de l'event (ou
    // agent) : un membre ne peut PAS s'auto-affecter. Lecture : sa propre affectation,
    // le propriétaire de l'event, ou un agent.
    match /staff_assignments/{id} {
      allow read:   if isSignedIn() && (
        resource.data.uid == request.auth.uid ||
        isEventOwnerOf(resource.data.eventId) ||
        isAgent()
      );
      // create/update : propriétaire de l'event (ou agent) UNIQUEMENT, et l'affectation
      // doit correspondre à un VRAI membre du roster event_staff — sinon un propriétaire
      // pourrait forger staff_assignments/{sonEvent__uidArbitraire} pour spammer un tiers
      // (notif « tu fais partie de l'équipe ») et lui débloquer l'accès scanner.
      allow create, update: if isAgent() || (
        isEventOwnerOf(request.resource.data.eventId) &&
        id == request.resource.data.eventId + '__' + request.resource.data.uid &&
        request.resource.data.role in ['scan', 'serveur', 'manager', 'dj'] &&
        request.resource.data.uid in get(/databases/$(database)/documents/event_staff/$(request.resource.data.eventId)).data.roster
      );
      allow delete: if isAgent() || isEventOwnerOf(resource.data.eventId);
    }

    // ── Commandes en soirée (précommandes + sur place), 1 doc/event ──────────
    // Doc unique event_orders/{eventId} avec un tableau `items`, mis à jour par
    // transaction (mergeItemsById) — client ET staff écrivent (le client ajoute
    // ses consos, le staff sert/encaisse). Modèle pragmatique (comme les
    // messages) : write réservé aux connectés ; la logique métier + l'historique
    // + l'annulation manager sont les garde-fous applicatifs.
    match /event_orders/{eventId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn();
    }

    // ── Historique commun des actions (litiges) ──────────────────────────────
    // Lecture réservée au manager de l'event (propriétaire) ou à un agent.
    // Écriture (append) par tout acteur connecté qui journalise son action.
    match /event_order_log/{eventId} {
      allow read:  if isAgent() || isEventOwnerOf(eventId);
      allow write: if isSignedIn();
    }

    // ── Config éditoriale globale de l'accueil ────────────────────────────────
    // app_config/homepage_actualite = carrousel « Actualité » curé par l'admin
    // (titre, accent, liste ordonnée d'eventIds). Lecture PUBLIQUE (le carrousel
    // s'affiche pour les visiteurs non connectés) ; écriture réservée aux agents.
    // Portée limitée au SEUL doc voulu (pas de wildcard read:true qui rendrait
    // public tout futur doc app_config/*). Validation de forme cÔté serveur =
    // défense en profondeur (le client normalise déjà, mais on ne s'y fie pas :
    // un token agent forgé hors UI ne peut pas écrire un doc surdimensionné).
    match /app_config/homepage_actualite {
      allow read:  if true;
      allow write: if isAgent()
        && request.resource.data.active is bool
        && request.resource.data.title is string && request.resource.data.title.size() <= 80
        && request.resource.data.subtitle is string && request.resource.data.subtitle.size() <= 140
        && request.resource.data.accent in ['teal', 'gold', 'pink']
        && request.resource.data.eventIds is list && request.resource.data.eventIds.size() <= 12;
    }
  }
}
