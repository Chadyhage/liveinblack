rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAgent() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'agent';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Super-admin « bootstrap » : seul moyen légitime de poser role:'agent'
    // (les vrais agents sont ensuite créés par un agent existant). DOIT rester
    // aligné avec VITE_SUPER_ADMIN_EMAILS côté front (src/pages/LoginPage.jsx).
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email in ['hagechady4@gmail.com'];
    }

    // Organisateur propriétaire de l'event (createdBy OU organizerId — les deux
    // champs sont toujours écrits ensemble à la création, voir events/{id}).
    function isEventOwnerOf(eventId) {
      let ev = get(/databases/$(database)/documents/events/$(eventId)).data;
      return isSignedIn() && (ev.createdBy == request.auth.uid || ev.organizerId == request.auth.uid);
    }

    // ── Users ──────────────────────────────────────────────────────────────────
    // Read: any signed-in user can see profiles (needed for messaging contacts sync)
    // Write: le propriétaire édite son profil (nom, avatar, confidentialité, switch
    // d'interface…) MAIS ne peut PAS s'auto-promouvoir : role/activeRole = 'agent'
    // est réservé aux agents / super-admin. Ferme l'escalade de privilèges
    // client → agent (isAgent() lit users/{uid}.role, champ que le propriétaire
    // pouvait sinon écrire lui-même).
    match /users/{uid} {
      allow read:   if isSignedIn();
      allow create: if isSuperAdmin() || (isOwner(uid) && request.resource.data.get('role', 'client') != 'agent');
      // Le propriétaire édite son profil MAIS ne peut pas s'octroyer de privilèges :
      //  - jamais role/activeRole = 'agent' (escalade admin) ;
      //  - jamais s'auto-valider (status → 'active' réservé aux agents) ;
      //  - jamais s'auto-accorder un rôle : role ne peut changer QUE vers un rôle
      //    déjà présent dans enabledRoles (ou rester inchangé), et enabledRoles
      //    lui-même n'est pas modifiable. (.get() tolère les vieux docs.)
      allow update: if isAgent() || isSuperAdmin()
        || (isOwner(uid)
            && request.resource.data.get('role', 'client') != 'agent'
            && request.resource.data.get('activeRole', 'client') != 'agent'
            && (request.resource.data.get('status', '') != 'active' || resource.data.get('status', '') == 'active')
            && (request.resource.data.get('role', 'client') == resource.data.get('role', 'client')
                || request.resource.data.get('role', 'client') in resource.data.get('enabledRoles', [request.resource.data.get('role', 'client')]))
            && (!('enabledRoles' in resource.data) || request.resource.data.enabledRoles == resource.data.enabledRoles));
      allow delete: if isAgent();
    }

    // ── Applications / candidatures ────────────────────────────────────────────
    match /applications/{id} {
      allow read, write: if isSignedIn() && (
        resource == null ||
        resource.data.uid == request.auth.uid ||
        isAgent()
      );
    }

    // ── Pending validations ────────────────────────────────────────────────────
    match /pending_validations/{id} {
      allow read: if isAgent() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow write: if isAgent() || (isSignedIn() && (resource == null || resource.data.uid == request.auth.uid));
    }

    // ── Wallets ────────────────────────────────────────────────────────────────
    match /wallets/{uid} {
      allow read, write: if isOwner(uid) || isAgent();
    }

    // ── Public events (lecture publique, écriture = organisateur propriétaire ou agent) ──
    match /events/{id} {
      allow read: if true;
      allow write: if isSignedIn() && (
        resource == null ||
        resource.data.createdBy == request.auth.uid ||
        resource.data.organizerId == request.auth.uid ||
        isAgent()
      );
      allow delete: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid ||
        resource.data.organizerId == request.auth.uid ||
        isAgent()
      );
    }

    // ── User data collections ──────────────────────────────────────────────────
    match /user_bookings/{uid} {
      allow read, write: if isOwner(uid) || isAgent();
    }
    match /user_events/{uid} {
      allow read, write: if isOwner(uid) || isAgent();
    }
    match /user_social/{uid} {
      allow read, write: if isOwner(uid) || isAgent();
    }
    // Events privés débloqués par code d'accès — suit l'utilisateur cross-device
    match /user_private_access/{uid} {
      allow read, write: if isOwner(uid);
    }
    // ── Conversations & messages ───────────────────────────────────────────────
    // Membre = présent dans participants (conv directe) ou participantIds (groupe).
    // Les requêtes clientes utilisent déjà array-contains sur ces champs,
    // donc ces règles sont compatibles avec les listeners existants.
    function isMemberOf(data) {
      return request.auth.uid in data.get('participants', [])
          || request.auth.uid in data.get('participantIds', []);
    }

    match /conversations/{id} {
      allow read:   if isSignedIn() && (isMemberOf(resource.data) || isAgent());
      allow create: if isSignedIn() && isMemberOf(request.resource.data);
      allow update, delete: if isSignedIn() && (isMemberOf(resource.data) || isAgent());
    }

    // conv_messages/{convId} : l'ID du doc = l'ID de la conversation.
    // On vérifie l'appartenance via le doc conversation. Si la conversation
    // n'existe pas/plus (création en cours ou suppression), on tolère —
    // nécessaire car les écritures conv/messages ne sont pas transactionnelles.
    match /conv_messages/{convId} {
      allow read, write: if isSignedIn() && (
        !exists(/databases/$(database)/documents/conversations/$(convId)) ||
        isMemberOf(get(/databases/$(database)/documents/conversations/$(convId)).data) ||
        isAgent()
      );
    }

    match /friend_requests/{id} {
      allow read:   if isSignedIn() && (resource.data.toId == request.auth.uid || resource.data.fromId == request.auth.uid || isAgent());
      allow create: if isSignedIn() && request.resource.data.fromId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.toId == request.auth.uid || resource.data.fromId == request.auth.uid || isAgent());
    }

    match /group_bookings/{id} {
      allow read:   if isSignedIn() && (isMemberOf(resource.data) || isAgent());
      allow create: if isSignedIn() && isMemberOf(request.resource.data);
      allow update, delete: if isSignedIn() && (isMemberOf(resource.data) || isAgent());
    }

    match /service_orders/{id} {
      allow read:   if isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid || isAgent());
      allow create: if isSignedIn() && (request.resource.data.buyerId == request.auth.uid || request.resource.data.sellerId == request.auth.uid);
      allow update, delete: if isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid || isAgent());
    }

    // ── Photos partagées dans les conversations (fallback base64) ──────────────
    // IDs aléatoires non devinables ; pas de champ convId exploitable en règle.
    match /conv_photos/{id} {
      allow read, write: if isSignedIn();
    }

    // ── Réservations finalisées par le webhook Stripe ──────────────────────────
    // Écrites uniquement par le webhook (Admin SDK). Le client lit la sienne
    // sur /paiement-reussi pour ADOPTER les billets du serveur au lieu d'en
    // générer en double.
    match /bookings/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAgent());
      allow write: if false;
    }

    // ── Marqueurs anti-double-restock (session Stripe expirée → stock relâché) ──
    // Purement serveur (Admin SDK) : empêche le webhook de restocker deux fois si
    // Stripe retente l'envoi du même événement checkout.session.expired.
    match /stock_releases/{sessionId} {
      allow read, write: if false;
    }

    // ── Registre anti-fraude des billets ───────────────────────────────────────
    // Source de vérité du ScannerPage. Seul le webhook Stripe (Admin SDK,
    // qui contourne ces règles) peut écrire paid:true. Côté client :
    // création uniquement avec paid:false (billets gratuits / en attente),
    // jamais de modification ni suppression.
    match /tickets/{code} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.paid == false;
      // L'agent peut tout modifier (validation scanner, etc). L'organisateur de
      // l'event ne peut QUE révoquer une invitation guestlist ou marquer un
      // check-in (jamais flipper `paid`, qui resterait réservé au webhook Stripe).
      // _syncedAt est ajouté automatiquement par syncDoc() à CHAQUE écriture
      // (voir firestore-sync.js) — doit être autorisé sinon le merge échoue.
      allow update: if isAgent() || (
        isEventOwnerOf(resource.data.eventId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['revoked', 'revokedAt', 'checkedInAt', 'checkedInBy', '_syncedAt'])
      );
      allow delete: if isAgent();
    }

    // ── Guestlist par événement (gérée par l'organisateur) ──────────────────────
    match /guestlists/{eventId} {
      allow read, write: if isEventOwnerOf(eventId) || isAgent();
    }
    // ── Statut de lecture cross-device ────────────────────────────────────────
    match /user_read_status/{uid} {
      allow read, write: if isOwner(uid) || isAgent();
    }

    // ── Playlists événements (lecture publique, écriture = participants connectés) ──
    match /event_playlists/{id} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ── Boosts ────────────────────────────────────────────────────────────────
    match /user_boosts/{uid} {
      allow read:  if isSignedIn();
      allow write: if isOwner(uid) || isAgent();
    }

    // Collection globale des boosts actifs — source de vérité partagée du Top 3.
    // Lecture PUBLIQUE (le Top 3 doit s'afficher pour les visiteurs non connectés).
    // Écriture réservée au webhook Stripe (Admin SDK, contourne ces règles) :
    // un client ne doit jamais pouvoir s'auto-attribuer un slot Top 3 sans payer.
    match /boosts/{id} {
      allow read:  if true;
      allow write: if isAgent();
    }

    // ── Billets scannés ────────────────────────────────────────────────────────
    match /used_tickets/{uid} {
      allow read, write: if isOwner(uid) || isAgent();
    }

    // ── Notifications in-app (cross-device) ─────────────────────────────────────
    // Sans cette règle, la collection était en deny par défaut → la sync
    // cross-device des notifications échouait silencieusement.
    match /notifications/{uid} {
      allow read, write: if isOwner(uid) || isAgent();
    }

    // ── Codes d'accès aux événements privés ─────────────────────────────────────
    // Collection plate {code} → { eventId, usedBy }. L'organisateur crée les
    // codes, le client connecté les valide (lookup O(1)) et marque usedBy.
    // Lecture/écriture réservée aux connectés (un code est un secret d'accès).
    match /event_access_codes/{code} {
      allow read, write: if isSignedIn();
    }

    // ── Signalements ──────────────────────────────────────────────────────────
    match /reports/{id} {
      allow read:  if isAgent();
      allow write: if isSignedIn();
    }

    // ── Demandes de suppression de compte ─────────────────────────────────────
    match /deletion_requests/{id} {
      allow read:  if isAgent() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow write: if isAgent() || (isSignedIn() && (resource == null || resource.data.uid == request.auth.uid));
    }

    // ── Inscriptions boîte (JeSuisUneBoitePage) ───────────────────────────────
    match /boite_registrations/{id} {
      allow read:  if isAgent();
      allow write: if isSignedIn();
      allow create: if true;  // Allow anonymous submissions too
    }

    // ── Profils prestataires ──────────────────────────────────────────────────
    // Allow signed-in users to read (for service marketplace discovery)
    match /providers/{uid} {
      allow read:  if isSignedIn();
      allow write: if isOwner(uid) || isAgent();
    }

    // ── Catalogues (read public pour marketplace) ─────────────────────────────
    match /catalogs/{uid} {
      allow read:  if isSignedIn();
      allow write: if isOwner(uid) || isAgent();
    }

    // ── Soldes vendeurs (ledger de reversement) ───────────────────────────────
    // Montant que la plateforme doit au vendeur quand le paiement n'a pas été
    // reversé automatiquement via Stripe Connect (ex. vendeur hors zone Stripe).
    // Écrit UNIQUEMENT par le webhook Stripe (Admin SDK, contourne ces règles) :
    // un vendeur ne doit jamais pouvoir gonfler son propre solde.
    match /seller_balances/{uid} {
      allow read:  if isOwner(uid) || isAgent();
      // Incrémenté par le webhook (Admin SDK, contourne ces règles). L'agent peut
      // décrémenter le solde au moment d'un reversement manuel (admin de confiance).
      allow write: if isAgent();
    }

    // ── Demandes de reversement (paiement manuel : virement / mobile money) ────
    // Le vendeur crée une demande sur SON solde ; l'agent la traite (marque payé).
    match /payout_requests/{id} {
      allow read:   if isSignedIn() && (resource.data.sellerId == request.auth.uid || isAgent());
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isAgent();
    }

    // ── Journal des reversements effectués (audit) ────────────────────────────
    match /payout_logs/{id} {
      allow read:  if isAgent();
      allow write: if isAgent();
    }

    // ── Staff d'un événement (roster serveur/manager) — mini-POS soirée ───────
    // Lecture : tout connecté (un serveur doit pouvoir lire son propre rôle).
    // Écriture : seul le propriétaire de l'event (manager implicite) ou un agent
    // gère le roster.
    match /event_staff/{eventId} {
      allow read:  if isSignedIn();
      allow write: if isAgent() || isEventOwnerOf(eventId);
    }

    // ── Commandes en soirée (précommandes + sur place), 1 doc/event ──────────
    // Doc unique event_orders/{eventId} avec un tableau `items`, mis à jour par
    // transaction (mergeItemsById) — client ET staff écrivent (le client ajoute
    // ses consos, le staff sert/encaisse). Modèle pragmatique (comme les
    // messages) : write réservé aux connectés ; la logique métier + l'historique
    // + l'annulation manager sont les garde-fous applicatifs.
    match /event_orders/{eventId} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn();
    }

    // ── Historique commun des actions (litiges) ──────────────────────────────
    // Lecture réservée au manager de l'event (propriétaire) ou à un agent.
    // Écriture (append) par tout acteur connecté qui journalise son action.
    match /event_order_log/{eventId} {
      allow read:  if isAgent() || isEventOwnerOf(eventId);
      allow write: if isSignedIn();
    }
  }
}
