# Stripe — copie ce fichier en .env.local et remplis avec tes vraies clés
# Mode TEST : pk_test_... / sk_test_...
# Mode LIVE : pk_live_... / sk_live_... (production uniquement)

VITE_STRIPE_PUBLISHABLE_KEY=<TA_CLÉ_PUBLIQUE_STRIPE>
STRIPE_SECRET_KEY=<TA_CLÉ_SECRÈTE_STRIPE>

# Stripe webhook — secret de signature pour /api/stripe-webhook
# Stripe Dashboard → Developers → Webhooks → ton endpoint → Signing secret (whsec_...)
# Configurer l'endpoint vers https://liveinblack.com/api/stripe-webhook
# Events à écouter : checkout.session.completed
STRIPE_WEBHOOK_SECRET=<whsec_...>

# Firebase Admin (côté serveur uniquement — service account)
# Firebase Console → Project Settings → Service Accounts → Generate new private key
# Copier le JSON et récupérer les 3 valeurs ci-dessous.
# IMPORTANT : la private key contient des \n littéraux à conserver tels quels dans Vercel.
FIREBASE_PROJECT_ID=liveinblack-15d30
FIREBASE_CLIENT_EMAIL=<firebase-adminsdk-...@liveinblack-15d30.iam.gserviceaccount.com>
FIREBASE_PRIVATE_KEY=<-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n>

# Super admin — liste d'emails (séparés par virgules) qui auront le rôle 'agent' au login.
# Laisser vide si tu veux gérer les admins uniquement via Firestore (role: 'agent').
# En prod : configurer dans Vercel → Project Settings → Environment Variables (préfixe VITE_ obligatoire pour Vite).
VITE_SUPER_ADMIN_EMAILS=<email1@example.com,email2@example.com>

# Firebase Cloud Messaging — clé VAPID pour les notifications push web
# Firebase Console → Project Settings → Cloud Messaging → Web Push certificates → Generate key pair
# Si vide, les notifications push sont désactivées (le reste de l'app fonctionne).
VITE_FIREBASE_VAPID_KEY=<TA_CLÉ_VAPID>
