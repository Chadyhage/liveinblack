# MongoDB Atlas (cluster déjà existant côté client)
MONGODB_URI=

# Auth.js — génère avec `npx auth secret` ou `openssl rand -base64 32`
AUTH_SECRET=

# Resend (déjà utilisé côté legacy pour les emails transactionnels)
RESEND_API_KEY=

# Cloudinary (remplace Firebase Storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Web Push standard (VAPID) — remplace Firebase Cloud Messaging
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Stripe (clés de TEST/sandbox pendant la migration — jamais les clés live avant la phase 10)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# FedaPay (mobile money, sandbox pendant la migration)
FEDAPAY_SECRET_KEY=
FEDAPAY_WEBHOOK_SECRET=

# Site public (URLs de retour paiement — jamais déduit d'Origin/Host, cf. audit H06)
PUBLIC_SITE_URL=https://liveinblack.com

# Cron de versement organisateur (/api/cron/payouts) — génère avec `openssl rand -hex 32`.
# Échoue FERMÉ si absent (audit C09) : ne jamais laisser vide en production.
CRON_SECRET=

# Allowlist super-admin (remplacé phase 9 par un flag `superAdmin` en base — gardé ici en transition)
SUPER_ADMIN_EMAILS=
